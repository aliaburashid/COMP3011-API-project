# Server
PORT=3000

# MongoDB Atlas connection string — replace with your own Atlas URI
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/comp3011-api

# JWT secret key — replace with a long random string
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
