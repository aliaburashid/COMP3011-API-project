# Server
PORT=3000

# MongoDB Atlas connection string — to find yours:
# 1. Go to https://cloud.mongodb.com
# 2. Click your cluster → "Connect" → "Drivers"
# 3. Copy the connection string and replace <username> and <password> with your DB user credentials
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/comp3011-api

# JWT secret key — replace with a long random string
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
