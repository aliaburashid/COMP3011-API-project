            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"testuser2\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup"
