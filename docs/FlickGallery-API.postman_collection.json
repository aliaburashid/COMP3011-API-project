        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json(); if (j.message && j.message._id) pm.collectionVariables.set('messageId', j.message._id); if (j.message && j.message.recipient) pm.collectionVariables.set('recipientId', j.message.recipient._id || j.message.recipient);"
                ],
                "type": "text/javascript"
              }
            }
